[0.784, "o", "\u001b[4;2H\u001b[38;2;215;119;87m в–ҳв–ҳ в–қв–қ  \u001b[4;12H\u001b(B\u001b[m\u001b[38;2;60;64;72m~/Repos/dmccaffery/demo\u001b[39m\r\n\u001b[K\r\n\u001b[K\r\n\u001b[38;2;60;64;72m\u001b[48;2;55;55;55mвқҜ \u001b[38;2;255;255;255mCreate a go CLI that tells a joke!\u001b[39m                                                                                                                                                                                              \u001b[9;1H\u001b[49m\u001b[38;2;255;255;255mвҸә\u001b[39m I'll create a Go CLI that tells jokes. Let me check the current state of the directory first.\u001b[K\u001b[11;1H \u001b[C\u001b[38;2;60;64;72mRead \u001b[1m1\u001b(B\u001b[m\u001b[38;2;60;64;72m file, ran \u001b[1m1\u001b(B\u001b[m\u001b[38;2;60;64;72m shell command \u001b[39m\u001b[K\u001b[13;1H\u001b[38;2;255;255;255mвҸә\u001b[C\u001b[39mNow let me create the joke CLI:\u001b[K\u001b[15;1H\u001b[38;2;94;255;108mвҸә\u001b[C\u001b[39m\u001b[1mWrite\u001b(B\u001b[m(main.go)\u001b[K\r\n\u001b[38;2;60;64;72m  вҺҝ В \u001b[39mWrote\u001b[C\u001b[1m33\u001b[C\u001b(B\u001b[mlines\u001b[Cto\u001b[C\u001b[1mmain.go\r\n\u001b(B\u001b[m \u001b[C   \u001b[38;2;248;248;242m\u001b[2m  1 \u001b(B\u001b[m\u001b[38;2;117;113;94m// Command demo is a tiny CLI that tells a joke.\r\n\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m  2 \u001b(B\u001b[m\u001b[38;"]
