[0.000, "o", "\u001b[1mWrite\u001b(B\u001b[m(commit.sh)\r\n\u001b[38;2;60;64;72m  вҺҝ В \u001b[39mWrote \u001b[1m12\u001b(B\u001b[m lines to\u001b[C\u001b[1mcommit.sh\u001b[20;6H\u001b(B\u001b[m\u001b[38;2;248;248;242m\u001b[2m  1 \u001b(B\u001b[m\u001b[38;2;117;113;94m#!/usr/bin/env sh\r\n\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m  2 \u001b(B\u001b[m\u001b[38;2;166;226;46mset\u001b(B\u001b[m\u001b[38;2;248;248;242m -eu\u001b[39m\u001b[K\u001b[22;6H\u001b[38;2;248;248;242m\u001b[2m  3 \r\n\u001b(B\u001b[m \u001b[C   \u001b[38;2;248;248;242m\u001b[2m  4 \u001b(B\u001b[m\u001b[38;2;248;248;242mgit add .gitignore README.md go.mod jokes.go main.go\u001b[39m\u001b[K\u001b[24;3H   \u001b[38;2;248;248;242m\u001b[2m  5 \u001b(B\u001b[m\u001b[38;2;248;248;242mgit commit -m \u001b(B\u001b[m\u001b[38;2;230;219;116m\"feat: add jokes CLI\u001b[39m\u001b[K\u001b[25;6H\u001b[38;2;248;248;242m\u001b[2m  6 \u001b[26;3H\u001b(B\u001b[m   \u001b[38;2;248;248;242m\u001b[2m  7 \u001b(B\u001b[m\u001b[38;2;248;248;242mA small Go CLI that tells jokes from a built-in library, grouped by\u001b[27;6H\u001b[2m  8 \u001b(B\u001b[m\u001b[38;2;248;248;242mcategory (dad, programming, pun). Supports random selection, multiple\r\n\u001b[39m \u001b[C   \u001b[38;2;248;248;242m\u001b[2m  9 \u001b(B\u001b[m\u001b[38;2;248;248;242mjokes via -count, -all to \u001b(B\u001b[m\u001b[38;2;166;226;46mprint\u001b(B\u001b[m\u001b[38;2;248;248;242m a whole category, and -li"]
