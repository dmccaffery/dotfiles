[0.000, "o", "K\u001b[35;1H\u001b[38;2;255;255;255mвҸә\u001b[C\u001b[39mIt builds, vets clean,\u001b[Cand\u001b[Ctells\u001b[Ca\u001b[Crandom\u001b[Cjoke\u001b[Ceach\u001b[Crun.\u001b[CHere's\u001b[Cwhat\u001b[CI\u001b[Ccreated:\u001b[37;1H \u001b[C\u001b[38;2;177;185;249m\u001b[1mmain.go\u001b(B\u001b[m вҖ” a single-file Go\u001b[CCLI th\u001b[Ct picks\u001b[Ca random joke from a small\u001b[Cset and prints\u001b[Cthe\u001b[Csetup\u001b[Cand\u001b[Cpunchline.\u001b[39;3H- Uses \u001b[38;2;177;185;249mmath/rand/v2\u001b[39m (modern, au\u001b[Co-seeded вҖ” no \u001b[38;2;177;185;249mrand.Seed\u001b[C\u001b[39mboilerplate ne\u001b[Cded).\u001b[C\u001b[K\u001b[40;3H-\u001b[C\u001b[38;2;177;185;249mgo vet\u001b[C\u001b[39mpasses;\u001b[Cthree\u001b[Cruns\u001b[Cproduced\u001b[Cthree\u001b[Cdifferent\u001b[Cjokes.\u001b[41;3H\u001b[K\nTo run it your\u001b[Celf: \u001b[38;2;177;185;249mgo run .\u001b[39m (\u001b[Cr \u001b[38;2;177;185;249mgo build -o joke . && ./joke\u001b[39m).\u001b[44;3HOne e\u001b[Cv\u001b[Cronment note: the Go\u001b[Cbuild cache lives outside the sandbox,\u001b[Cso\u001b[CI\u001b[Chad\u001b[Cto\u001b[Cset\u001b[C\u001b[38;2;177;185;249mGOCACHE=\"$TMPDIR/go-build\"\u001b[C\u001b[39mfor\u001b[Cthe\u001b[Cbuild\u001b[Cto\u001b[Cwork\u001b[Chere.\u001b[CYour\u001b[Cown\u001b[Cshell\u001b[Coutside\u001b[Cthe\u001b[Csandbox\u001b[Cwon't\u001b[Cneed\u001b[Cthat.\u001b[47;3H"]
