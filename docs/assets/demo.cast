[0.035, "o", "\u001b[?2026h\u001b[3d\u001b[K\ngo build -o jokes\u001b[C.  \u001b[C  \u001b[32m# or: go run .\u001b[39m\u001b[K\u001b[5;11H     \u001b[5;35H\u001b[32mone random joke\u001b[6;3H\u001b[39m./jokes\u001b[C-category\u001b[Cprogramming\u001b[C\u001b[32m# one programming joke\u001b[7;3H\u001b[39m./jokes -count 3\u001b[C     \u001b[C      \u001b[C\u001b[32m# three random jokes\u001b[39m\u001b[K\u001b[8;3H./jok\u001b[Cs -ca\u001b[Cegory\u001b[Cd\u001b[Cd -all    \u001b[32m# every dad joke\u001b[39m\u001b[K\u001b[9;3H./jokes -list\u001b[9;33H\u001b[32m# list categories\u001b[11;3H\u001b[39mIt ships\u001b[Cwith\u001b[C15\u001b[Cjokes across three ca\u001b[Cegories (\u001b[38;2;177;185;249mdad\u001b[39m, \u001b[38;2;177;185;249mprogrammin\u001b[C\u001b[39m, \u001b[38;2;177;185;249mpun\u001b[39m)\u001b[11;75HAn unknown category\u001b[Cexits\u001b[12;3Hnon-zero with the\u001b[Cvalid\u001b[Coptions.\u001b[C\u001b[38;2;177;185;249mgo vet\u001b[C\u001b[39mand\u001b[C\u001b[38;2;177;185;249mgo build\u001b[C\u001b[39mboth\u001b[Cpass,\u001b[Cand\u001b[CI\u001b[Cexercised\u001b[Cevery\u001b[Cmode\u001b[Cabove\u001b[CвҖ”\u001b[Call\u001b[13;3Hworking.\u001b[14;3H\u001b[K\nAdding a joke\u001b[Cis a one-\u001b[Cine append to the\u001b[C\u001b[38;2;177;185;249mjokes\u001b[C\u001b[39mslice\u001b[Cin\u001b[C\u001b[38;2;177;185;249mjokes.g\u001b(B\u001b[m\u001b[?2026l\u001b[38;2;177;185;249mo\u001b[39m,\u001b[Ce.g.\u001b[C\u001b[38;2;177;185;249m{\"dad\", \"Setup?\", \u001b[16;3H\"Punchline.\""]
