[0.017, "o", "\u001b[?2026h\u001b[3;6H\u001b[K\u001b[4;8H\u001b[38;2;248;248;242m\u001b[2m6\u001b[4;11H\u001b(B\u001b[m\u001b[38;2;230;219;116mma\u001b[Ch/rand/v2\"\u001b[5;8H\u001b(B\u001b[m\u001b[38;2;248;248;242m\u001b[2m7\u001b[5;11H\u001b(B\u001b[m\u001b[38;2;230;219;116mos\"\u001b[39m\u001b[K\u001b[6;8H\u001b[38;2;248;248;242m\u001b[2m8\u001b[C\u001b(B\u001b[m\u001b[38;2;248;248;242m)\u001b[39m\u001b[K\u001b[7;8H\u001b[38;2;248;248;242m\u001b[2m9\u001b(B\u001b[m\u001b[C\u001b[K\u001b[8;7H\u001b[38;2;248;248;242m\u001b[2m10\u001b[C\u001b(B\u001b[m\u001b[38;2;117;113;94m// joke is a classic two-part setup/punchline gag.\u001b[9;6H\u001b(B\u001b[m\u001b[38;2;60;64;72mвҖҰ +23 lines \u001b[39m\u001b[K\u001b[10;6H\u001b[K\u001b[11;3H\u001b[38;2;60;64;72mRan \u001b[1m1\u001b(B\u001b[m\u001b[38;2;60;64;72m shell command \u001b[39m\u001b[12;3H\u001b[K\r\n\u001b[38;2;255;255;255mвҸә\u001b[C\u001b[39mThe\u001b[CGo\u001b[Cbuild\u001b[Ccache\u001b[Cis\u001b[Coutside\u001b[Cthe\u001b[Csandbox.\u001b[CLet\u001b[Cme\u001b[Cpoint\u001b[Cit\u001b[Cat\u001b[Ca\u001b[Cwritable\u001b[Clocation:\r\n\u001b[K\u001b[15;3H\u001b[38;2;60;64;72mRan \u001b[1m1\u001b(B\u001b[m\u001b[38;2;60;64;72m shell command \u001b[39m\u001b[16;3H\u001b[K\r\n\u001b[38;2;255;255;255mвҸә\u001b[C\u001b[39mIt\u001b[Cbuilds,\u001b[Cvets\u001b[Cclean,\u001b[Cand\u001b[Ctells\u001b[Ca\u001b[Crandom\u001b[Cjoke\u001b[Ceach\u001b[Crun.\u001b[CHere's\u001b[Cwhat\u001b[CI\u001b[Ccreated:\r\n\u001b[K\u001b[19;3H\u001b[38;2;177;185;249m\u001b[1mmain.go\u001b[C\u001b(B\u001b[mвҖ”\u001b[Ca\u001b[Csingle-file\u001b[?2026l"]
[0.001, "o", "\u001b[CGo\u001b[CCLI\u001b[Cthat\u001b[Cpicks\u001b[Ca\u001b[Crandom\u001b[Cjoke\u001b[Cfrom\u001b[Ca\u001b[Csmall\u001b[Cset\u001b[Cand\u001b[Cprints\u001b[Cthe\u001b[Csetup\u001b[Cand\u001b[Cpunchline.\u001b[20;3H\u001b[K\n-\u001b[CUses\u001b[C\u001b[38;2;177;185;249mmath/rand/v2\u001b[C\u001b[39m(modern,\u001b[Cauto-seeded\u001b[CвҖ”\u001b[Cno\u001b[C\u001b[38;2;177;185;249mrand.Seed\u001b[C\u001b[39mboilerplate\u001b[Cneeded).\u001b[22;5H\u001b[38;2;177;185;249mgo vet\u001b[39m passes; three runs produced three\u001b[Cdifferent jokes.\u001b[K\u001b[23;3H\u001b[K\nTo\u001b[Crun\u001b[Cit\u001b[Cyourself:\u001b[C\u001b[38;2;177;185;249mgo run .\u001b[C\u001b[39m(or\u001b[C\u001b[38;2;177;185;249mgo build -o joke . && ./joke\u001b[39m).\u001b[25;3H\u001b[K\nOne\u001b[Cenvironment\u001b[Cnote:\u001b[Cthe\u001b[CGo\u001b[Cbuild\u001b[Ccache\u001b[Clives\u001b[Coutside\u001b[Cthe\u001b[Csandbox,\u001b[Cso\u001b[CI\u001b[Chad\u001b[Cto\u001b[Cset\u001b[C\u001b[38;2;177;185;249mGOCACHE=\"$TMPDIR/go-build\"\u001b[C\u001b[39mfor\u001b[Cthe\u001b[Cbuild\u001b[Cto\u001b[Cwork\u001b[Chere.\u001b[CYour\u001b[Cown\u001b[Cshell\u001b[Coutside\u001b[Cthe\u001b[Csandbox\u001b[Cwon't\u001b[Cneed\u001b[Cthat.\u001b[27;3H\u001b[K\nWant\u001b[Cme\u001b[Cto\u001b[Cadd\u001b[Canything\u001b[CвҖ”\u001b[Ca\u001b[C\u001b[38;2;177;185;249m--list\u001b[C\u001b[39mflag\u001b[Cto\u001b[Cshow\u001b[Call\u001b[Cjokes,\u001b[Ca\u001b[Ccategory/topic\u001b[Cfilter,\u001b[Cor\u001b[Cfetching\u001b[Ca\u001b[Clive\u001b[Cjoke\u001b[Cfrom\u001b[Can\u001b[CAPI?\u001b[29;3H\u001b[K\r\n\u001b[38;2;60;64;72mвң»\u001b["]
