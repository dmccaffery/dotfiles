{
  "respectGitignore": true,
  "cleanupPeriodDays": 7,
  "env": {
    "IS_DEMO": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob",
      "Grep",
      "WebSearch",
      "Edit(/tmp/**)",
      "Edit(~/.cache/agent/worktrees/**)",
      "Bash(pwd)",
      "Bash(hostname)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(id *)",
      "Bash(uptime)",
      "Bash(uname)",
      "Bash(uname *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(command -v *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(brew list)",
      "Bash(brew list *)",
      "Bash(brew search *)",
      "Bash(brew info *)",
      "Bash(brew bundle check)",
      "Bash(brew bundle check *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git blame *)",
      "Bash(git ls-files)",
      "Bash(git ls-files *)",
      "Bash(git rev-parse *)",
      "Bash(git config --get *)",
      "Bash(git branch)",
      "Bash(git branch --list)",
      "Bash(git branch --list *)",
      "Bash(git stash list)",
      "Bash(git worktree list)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote get-url *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Read(~/.aws)",
      "Read(~/.config/gcloud)",
      "Read(~/.ssh)",
      "Read(~/.gnupg)",
      "Read(**/.env*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/worktree start"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/worktree end"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/agent-tmux-status waiting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/agent-tmux-status attention"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/agent-tmux-status clear"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/agent-tmux-status clear"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/share/scripts/agent-tmux-status clear"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "head"
  },
  "statusLine": {
    "type": "command",
    "command": "oh-my-posh claude --config ~/.config/oh-my-posh/claude.yaml"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "codeload.github.com",
        "ghcr.io",
        "codeberg.org",
        "code.forgejo.org",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "formulae.brew.sh",
        "nodejs.org",
        "proxy.golang.org",
        "sum.golang.org",
        "index.golang.org",
        "registry.terraform.io",
        "localhost",
        "127.0.0.1",
        "::1"
      ],
      "allowUnixSockets": [
        "/tmp",
        "/private/tmp"
      ],
      "allowLocalBinding": true,
      "allowMachLookup": [
        "com.apple.SecurityServer",
        "com.apple.trustd",
        "com.apple.trustd.agent",
        "com.apple.mDNSResponder",
        "com.apple.dnssd",
        "com.apple.system.opendirectoryd.api",
        "com.apple.system.DirectoryService.api"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/Repos",
        "~/.cache/agent/worktrees",
        "~/.cache/uv",
        "~/.cache/pip",
        "~/.cache/go",
        "~/.local/share/go",
        "/tmp",
        "~/.npm"
      ],
      "denyRead": [
        "~/.aws",
        "~/.config/gcloud",
        "~/.ssh",
        "~/.gnupg",
        "**/.env*"
      ],
      "allowRead": [
        "~/Repos",
        "~/.config",
        "~/.cache",
        "~/.local/runtime",
        "~/.local/share",
        "~/.npm",
        "/opt/homebrew",
        "/tmp"
      ]
    },
    "enableWeakerNestedSandbox": false,
    "enableWeakerNetworkIsolation": false
  },
  "feedbackSurveyRate": 0,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "plansDirectory": "./.claude/plans",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "theme": "custom:cyberdream",
  "editorMode": "vim"
}
