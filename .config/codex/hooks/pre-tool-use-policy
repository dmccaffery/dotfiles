#!/usr/bin/env sh

set -eu

# Codex PreToolUse deny-hook — recovers the credential protection that Claude
# Code gets from sandbox.filesystem.denyRead and Bash(security *). Codex's
# Seatbelt sandbox only restricts WRITES in workspace-write mode, so reads of
# ~/.ssh, ~/.aws, ~/.config/gcloud, ~/.gnupg, and .env files are not blocked at
# the OS layer. This hook blocks them at the tool layer instead — the same set
# OpenCode denies in its `bash` rules (.config/opencode/opencode.jsonc).
#
# Codex pipes the PreToolUse event as JSON on stdin. We only run for the Bash
# tool (matcher "^Bash$" in config.toml), so .tool_input.command is the shell
# line about to execute. Emitting permissionDecision "deny" stops it before it
# runs; printing nothing (exit 0) lets execpolicy / approval_policy decide.

input=$(cat)
command=$(printf '%s' "${input}" | jq -r '.tool_input.command // empty' 2> /dev/null || true)

# No command to inspect (non-Bash payload, or parse miss) — defer, don't block.
[ -n "${command}" ] || exit 0

deny() {
	# PreToolUse deny decision (Codex hooks protocol). A reason is surfaced to
	# the model so it can adjust instead of silently failing.
	printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"%s"}}\n' "$1"
	exit 0
}

# Credential paths (~/.ssh, ~/.aws, ~/.config/gcloud, ~/.gnupg, any .env*) and the
# macOS `security` keychain tool. Matched case-insensitively against the whole
# command so it catches the path wherever it appears in the line.
if printf '%s' "${command}" | grep -qiE '(^|[^[:alnum:]_])\.env|\.ssh([/[:space:]]|$)|\.aws([/[:space:]]|$)|\.config/gcloud|\.gnupg([/[:space:]]|$)|(^|[;&|/[:space:]])security([[:space:]]|$)'; then
	deny "blocked by codex policy: command references a credential path (~/.ssh, ~/.aws, ~/.config/gcloud, ~/.gnupg, .env) or the macOS keychain"
fi

exit 0
