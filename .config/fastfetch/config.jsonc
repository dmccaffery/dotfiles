{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    // TODO: enable when tmux supports kitty, see: https://github.com/tmux/tmux/issues/4902
    // "logo": {
    //     "type": "kitty",
    //     "width": 60,
    //     "printRemaining": false,
    //     "recache": true,
    //     "source": "~/.local/share/wallpapers/london-night.png",
    //     "padding": {
