{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "read": {
            "*": "allow",
            "~/.aws": "deny",
            "~/.aws/**": "deny",
            "~/.config/gcloud": "deny",
            "~/.config/gcloud/**": "deny",
            "~/.ssh": "deny",
            "~/.ssh/**": "deny",
            "~/.gnupg": "deny",
            "~/.gnupg/**": "deny",
            ".env*": "deny",
            "**/.env*": "deny",
        },
        "list": {
            "*": "allow",
            "~/.aws": "deny",
            "~/.aws/**": "deny",
            "~/.config/gcloud": "deny",
            "~/.config/gcloud/**": "deny",
            "~/.ssh": "deny",
            "~/.ssh/**": "deny",
            "~/.gnupg": "deny",
            "~/.gnupg/**": "deny",
            ".env*": "deny",
            "**/.env*": "deny",
        },
        "glob": {
            "*": "allow",
            "~/.aws*": "deny",
            "~/.config/gcloud*": "deny",
            "~/.ssh*": "deny",
            "~/.gnupg*": "deny",
            ".env*": "deny",
            "**/.env*": "deny",
        },
        "grep": "allow",
        "edit": {
            "*": "ask",
            "~/.config": "deny",
            "~/.config/**": "deny",
            "~/.cache": "deny",
            "~/.cache/**": "deny",
            "~/.local": "deny",
            "~/.local/**": "deny",
            "/opt/homebrew": "deny",
            "/opt/homebrew/**": "deny",
            "~/Repos": "ask",
            "~/Repos/**": "ask",
            "~/.cache/agent/worktrees": "allow",
            "~/.cache/agent/worktrees/**": "allow",
            "~/.cache/uv": "ask",
            "~/.cache/uv/**": "ask",
            "~/.cache/pip": "ask",
            "~/.cache/pip/**": "ask",
            "~/.cache/go": "ask",
            "~/.cache/go/**": "ask",
            "~/.local/share/go": "ask",
            "~/.local/share/go/**": "ask",
            "/tmp": "allow",
            "/tmp/**": "allow",
            "~/.npm": "ask",
            "~/.npm/**": "ask",
            "~/.aws": "deny",
            "~/.aws/**": "deny",
            "~/.config/gcloud": "deny",
            "~/.config/gcloud/**": "deny",
            "~/.ssh": "deny",
            "~/.ssh/**": "deny",
            "~/.gnupg": "deny",
            "~/.gnupg/**": "deny",
            ".env*": "deny",
            "**/.env*": "deny",
        },
        "external_directory": {
            "*": "deny",
            "~/Repos": "allow",
            "~/Repos/**": "allow",
            "~/.config": "allow",
            "~/.config/**": "allow",
            "~/.cache": "allow",
            "~/.cache/**": "allow",
            "~/.local/runtime": "allow",
            "~/.local/runtime/**": "allow",
            "~/.local/share": "allow",
            "~/.local/share/**": "allow",
            "~/.npm": "allow",
            "~/.npm/**": "allow",
            "/opt/homebrew": "allow",
            "/opt/homebrew/**": "allow",
            "/tmp": "allow",
            "/tmp/**": "allow",
            "~/.aws": "deny",
            "~/.aws/**": "deny",
            "~/.config/gcloud": "deny",
            "~/.config/gcloud/**": "deny",
            "~/.ssh": "deny",
            "~/.ssh/**": "deny",
            "~/.gnupg": "deny",
            "~/.gnupg/**": "deny",
            ".env*": "deny",
            "**/.env*": "deny",
        },
        "bash": {
            "*": "ask",
            "pwd": "allow",
            "hostname": "allow",
            "whoami": "allow",
            "id": "allow",
            "id *": "allow",
            "uptime": "allow",
            "uname": "allow",
            "uname *": "allow",
            "date": "allow",
            "date *": "allow",
            "ls": "allow",
            "ls *": "allow",
            "stat *": "allow",
            "file *": "allow",
            "wc *": "allow",
            "tree": "allow",
            "tree *": "allow",
            "which *": "allow",
            "type *": "allow",
            "command -v *": "allow",
            "echo *": "allow",
            "printf *": "allow",
            "cat *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "find *": "allow",
            "jq *": "allow",
            "yq *": "allow",
            "brew list": "allow",
            "brew list *": "allow",
            "brew search *": "allow",
            "brew info *": "allow",
            "brew bundle check": "allow",
            "brew bundle check *": "allow",
            "chmod +x commit.sh": "allow",
            "git status": "allow",
            "git status *": "allow",
            "git diff": "allow",
            "git diff *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "git blame *": "allow",
            "git ls-files": "allow",
            "git ls-files *": "allow",
            "git rev-parse *": "allow",
            "git config --get *": "allow",
            "git branch": "allow",
            "git branch --list": "allow",
            "git branch --list *": "allow",
            "git stash list": "allow",
            "git worktree list": "allow",
            "git remote": "allow",
            "git remote -v": "allow",
            "git remote get-url *": "allow",
            "git add *": "allow",
            "git restore *": "allow",
            "git checkout *": "allow",
            "git switch *": "allow",
            "git commit *": "allow",
            "test *": "allow",
            "* .env*": "deny",
            "* */.env*": "deny",
            "* ~/.aws*": "deny",
            "* ~/.config/gcloud*": "deny",
            "* ~/.ssh*": "deny",
            "* ~/.gnupg*": "deny",
            "* $HOME/.aws*": "deny",
            "* $HOME/.config/gcloud*": "deny",
            "* $HOME/.ssh*": "deny",
            "* $HOME/.gnupg*": "deny",
        },
        "websearch": "allow",
        "webfetch": "ask",
        "question": "allow",
        "todowrite": "allow",
        "doom_loop": "deny",
    },
}
