#!/usr/bin/env sh

set -eu

tty=/dev/tty

default_color=$(tput sgr 0 2> /dev/null || true)
blue=$(tput setaf 4 2> /dev/null || true)
green=$(tput setaf 2 2> /dev/null || true)
yellow=$(tput setaf 3 2> /dev/null || true)

info() {
	printf '%s==> %s%s\n' "$blue" "$1" "$default_color" > "$tty" 2> /dev/null || true
}

success() {
	printf '%s==> %s%s\n' "$green" "$1" "$default_color" > "$tty" 2> /dev/null || true
}

warn() {
	printf '%s==> %s%s\n' "$yellow" "$1" "$default_color" > "$tty" 2> /dev/null || true
}

worktree_path="${1:-}"

if [ -z "${worktree_path:-}" ] && [ ! -t 0 ]; then
	input=$(cat)
	if [ -n "${input:-}" ]; then
		worktree_path=$(printf '%s' "${input}" | jq -r '.worktree_path // empty' 2> /dev/null || true)
	fi
fi

if [ -z "${worktree_path:-}" ]; then
	printf 'end-worktree: no worktree path; pass as $1 or pipe JSON {"worktree_path":"..."}\n' >&2
	exit 1
fi

if [ ! -d "$worktree_path" ]; then
	warn "worktree at ${worktree_path} no longer exists; exiting gracefully"
	exit 0
fi

branch=$(git -C "$worktree_path" rev-parse --abbrev-ref HEAD 2> /dev/null || true)
common_dir=$(git -C "$worktree_path" rev-parse --git-common-dir 2> /dev/null || true)
main_repo=
if [ -n "${common_dir:-}" ]; then
	main_repo=$(cd "$(dirname "${common_dir}")" && pwd)
fi

uncommitted=$(git -C "$worktree_path" status --porcelain 2> /dev/null | wc -l | tr -d ' ')
unpushed=$(git -C "$worktree_path" rev-list --count HEAD --not --remotes 2> /dev/null || echo 0)
if [ "${uncommitted}" != "0" ] || [ "${unpushed}" != "0" ]; then
	warn "${worktree_path} [${branch:-?}] — uncommitted: ${uncommitted}, unpushed: ${unpushed}"
fi

session_name=$(basename -- "${worktree_path}")
if command -v tmux > /dev/null 2>&1; then
	tmux kill-session -t "${session_name}" 2> /dev/null || true
fi

if [ -n "${main_repo:-}" ]; then
	git -C "${main_repo}" worktree remove --force "${worktree_path}" 2> /dev/null || true
else
	git worktree remove --force "${worktree_path}" 2> /dev/null || true
fi

if [ -n "${branch:-}" ] && [ "${branch}" != "${branch##agent/*}" ]; then
	if [ -n "${main_repo:-}" ]; then
		git -C "${main_repo}" branch -D "${branch}" 2> /dev/null || true
	else
		git branch -D "${branch}" 2> /dev/null || true
	fi
fi

success "removed ${session_name}"
