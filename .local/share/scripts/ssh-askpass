#!/usr/bin/env bash

if [[ "${1}" == "Confirm user presence"* ]]; then
	echo
else
	desc="${1:-}"
	hash_type=$(echo "${desc}" | awk -F':' '{print $1}')
	if [[ "${hash_type}" == *"SHA256" ]]; then
		sha256_hash=$(echo "${1}" | awk -F':' '{print $2}')
		ask_prompt="SETDESC ${desc}\nOPTION allow-external-password-cache\nSETKEYINFO s/${sha256_hash}\nGETPIN"
	else
		ask_prompt="SETDESC ${desc}\nGETPIN"
	fi

	pin_entry=$(echo -e "${ask_prompt}" | /opt/homebrew/bin/pinentry-mac | grep D | tr -d '\n')
	echo "${pin_entry:2}"
fi
