#!/usr/bin/env sh

set -eu

default_color=$(tput sgr 0)
blue="$(tput setaf 4)"
info() {
	printf "%s==> %s%s\n" "$blue" "$1" "$default_color"
}
green="$(tput setaf 2)"
success() {
	printf "%s==> %s%s\n" "$green" "$1" "$default_color"
}
yellow="$(tput setaf 3)"
warn() {
	printf "%s==> %s%s\n" "$yellow" "$1" "$default_color"
}
red="$(tput setaf 1)"
error() {
	printf "%s==> %s%s\n" "$red" "$1" "$default_color"
}

usage() {
	cat << 'USAGE'
usage: brewfile <add|remove> <package>... [brew bundle flags...]

Wraps `brew bundle <add|remove> --global` then `brew bundle install --global`
so the global Brewfile and the installed state stay in sync in one command.

Flags after the action are passed through to `brew bundle`, so
`brewfile add --cask ghostty` and `brewfile add --tap user/tap` work.

On `add`, any formula/cask/tap that comes from a non-official tap (a
`user/tap/...` reference) is checked against trust.json; if it is not already
trusted you are prompted to `brew trust` it before the install runs.

Examples:
  brewfile add jq
  brewfile add --cask ghostty
  brewfile remove jq
USAGE
}

if [ "$#" -lt 1 ]; then
	usage >&2
	exit 1
fi

action="$1"
shift

case "$action" in
add | remove) ;;
-h | --help)
	usage
	exit 0
	;;
*)
	error "unknown action: ${action}"
	usage >&2
	exit 1
	;;
esac

if [ "$#" -lt 1 ]; then
	error "missing package argument"
	usage >&2
	exit 1
fi

# brew reads its trusted set from ${XDG_CONFIG_HOME}/homebrew/trust.json when
# XDG_CONFIG_HOME is set, falling back to ~/.homebrew/trust.json otherwise.
if [ -n "${XDG_CONFIG_HOME:-}" ]; then
	trust_file="${XDG_CONFIG_HOME}/homebrew/trust.json"
else
	trust_file="${HOME}/.homebrew/trust.json"
fi

# With HOMEBREW_REQUIRE_TAP_TRUST set, `brew bundle install` refuses to load a
# formula/cask/command from a non-official tap until it is listed in trust.json.
# Make sure the referenced entry is trusted before the install runs, offering to
# `brew trust` it when it is not. Only non-official references (a "user/tap/..."
# path) can ever need trusting; bare names resolve to homebrew/core|cask, which
# are trusted by default, so callers only pass slashed names here.
ensure_trusted() {
	_type="$1"
	_name="$2"

	case "$_type" in
	tap) _key="trustedtaps" ;;
	cask) _key="trustedcasks" ;;
	*) _key="trustedformulae" ;;
	esac

	if [ -r "$trust_file" ] &&
		jq -e --arg key "$_key" --arg name "$_name" \
			'(.[$key] // []) | index($name) != null' "$trust_file" > /dev/null 2>&1; then
		return 0
	fi

	if [ ! -r /dev/tty ]; then
		warn "${_type} '${_name}' is untrusted and no tty is available; brew bundle install may refuse it"
		return 0
	fi

	warn "${_type} '${_name}' is not trusted; brew will run its third-party code during install"
	printf "%s==> trust it now? [y/N] %s" "$yellow" "$default_color"
	read -r reply < /dev/tty || reply=""
	case "$reply" in
	[Yy] | [Yy][Ee][Ss])
		info "brew trust --${_type} ${_name}"
		brew trust "--${_type}" "$_name"
		;;
	*)
		warn "leaving ${_type} '${_name}' untrusted"
		;;
	esac
}

# On `add`, decide what kind of entry the flags select (formulae by default),
# then trust-check every non-official package named on the command line.
if [ "$action" = "add" ]; then
	trust_type="formula"
	for arg in "$@"; do
		case "$arg" in
		--cask | --casks) trust_type="cask" ;;
		--tap | --taps) trust_type="tap" ;;
		--formula | --formulae | --brews) trust_type="formula" ;;
		--vscode | --go | --cargo | --uv | --flatpak | --krew | --npm) trust_type="none" ;;
		esac
	done

	if [ "$trust_type" != "none" ]; then
		for arg in "$@"; do
			case "$arg" in
			-*) ;;                                      # brew bundle flag, not a package
			*/*) ensure_trusted "$trust_type" "$arg" ;; # tapped reference; may need trust
			*) ;;                                       # bare name → official tap, no trust needed
			esac
		done
	fi
fi

info "brew bundle ${action} --global $*"
brew bundle "${action}" "$@" --global

info "brew bundle install --global --zap"
brew bundle install --global --zap --upgrade

success "Brewfile in sync"
