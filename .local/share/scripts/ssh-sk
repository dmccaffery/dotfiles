#!/usr/bin/env sh

set -eu

# Security-key SSH workflow. tput is resolved defensively so the git signing
# resolver stays usable when git invokes `ssh-sk get --git` with no tty.
default_color=$(tput sgr 0 2> /dev/null || true)

blue=$(tput setaf 4 2> /dev/null || true)
info() {
	printf "%s==> %s%s\n" "$blue" "$1" "$default_color"
}

green=$(tput setaf 2 2> /dev/null || true)
success() {
	printf "%s==> %s%s\n" "$green" "$1" "$default_color"
}

yellow=$(tput setaf 3 2> /dev/null || true)
warn() {
	printf "%s==> %s%s\n" "$yellow" "$1" "$default_color"
}

red=$(tput setaf 1 2> /dev/null || true)
error() {
	printf "%s==> %s%s\n" "$red" "$1" "$default_color"
}

key_root="${XDG_CONFIG_HOME}/private/ssh"

usage() {
	cat >&2 <<-'EOF'
		usage: ssh-sk <command> [options]

		commands:
		  gen [user]       generate a resident ed25519-sk key and publish it when possible
		  get              load saved ed25519-sk stubs into the agent and update git allowed_signers
		  get --git        print the configured git signing key as key::<blob> (defaultKeyCommand)
	EOF
}

is_safe_user() {
	case "${1:-}" in
	'' | *[!A-Za-z0-9._@+-]* | . | ..) return 1 ;;
	*) return 0 ;;
	esac
}

prompt_for_yubikey() {
	message=$1

	if [ -r /dev/tty ] && [ -w /dev/tty ]; then
		printf "%s\n" "${message}" > /dev/tty
		printf "Insert a valid YubiKey, then press Enter to retry..." > /dev/tty
		IFS= read -r _ < /dev/tty || true
		printf "\n" > /dev/tty
		return 0
	fi

	printf "%s\n" "${message}" >&2
	return 1
}

current_serials() {
	ykman list --serials 2> /dev/null | awk 'NF {print $1}'
}

current_serials_or_prompt() {
	serials=$(current_serials)

	if [ -n "${serials:-}" ]; then
		printf "%s\n" "${serials}"
		return 0
	fi

	if prompt_for_yubikey "No YubiKey is currently inserted."; then
		serials=$(current_serials)

		if [ -n "${serials:-}" ]; then
			printf "%s\n" "${serials}"
			return 0
		fi
	fi

	return 1
}

single_current_serial() {
	if ! serials=$(current_serials_or_prompt); then
		serials=
	fi

	count=0
	selected=

	while IFS= read -r serial; do
		[ -n "${serial:-}" ] || continue
		count=$((count + 1))
		selected=${serial}
	done <<-EOF
		${serials}
	EOF

	case "${count}" in
	1)
		printf "%s\n" "${selected}"
		;;
	0)
		error "no YubiKey is currently inserted" >&2
		return 1
		;;
	*)
		error "insert exactly one YubiKey when generating a key" >&2
		return 1
		;;
	esac
}

current_user_key_blobs() {
	user=$1
	serials=$2

	while IFS= read -r serial; do
		[ -n "${serial:-}" ] || continue

		pub_file="${key_root}/${serial}/id_ed25519_sk_${user}.pub"
		[ -f "${pub_file}" ] || continue

		awk 'NF >= 2 {print $2}' "${pub_file}"
	done <<-EOF
		${serials}
	EOF
}

load_current_stubs() {
	serials=$1
	found=0
	loaded=0

	while IFS= read -r serial; do
		[ -n "${serial:-}" ] || continue

		key_dir="${key_root}/${serial}"
		[ -d "${key_dir}" ] || continue

		for key_file in "${key_dir}"/id_ed25519_sk_*; do
			[ -f "${key_file}" ] || continue

			case "${key_file}" in
			*.pub) continue ;;
			esac

			found=1
			if ssh-add "${key_file}" < /dev/null; then
				loaded=1
			fi
		done
	done <<-EOF
		${serials}
	EOF

	[ "${found}" -eq 1 ] || return 1
	[ "${loaded}" -eq 1 ] || return 1
}

match_agent_key_for_blobs() {
	key_blobs=$1
	available_keys=$(ssh-add -L 2> /dev/null || true)

	[ -n "${available_keys:-}" ] || return 1

	printf "%s\n" "${available_keys}" | while IFS= read -r line; do
		key_blob=$(printf "%s\n" "${line}" | cut -d ' ' -f 2)

		if printf "%s\n" "${key_blobs}" | grep -Fx -q "${key_blob}"; then
			printf "%s\n" "${line}"
			break
		fi
	done
}

# Print the currently inserted YubiKey's saved key for $1. Emits `key::<line>`
# on stdout for git to consume.
match_git_signing_key() {
	user=$1
	attempt=1

	while [ "${attempt}" -le 2 ]; do
		if ! serials=$(current_serials_or_prompt); then
			return 1
		fi

		load_current_stubs "${serials}" 1> /dev/null 2>&1 || true
		matched_blobs=$(current_user_key_blobs "${user}" "${serials}")

		if [ -n "${matched_blobs:-}" ]; then
			matched_key=$(match_agent_key_for_blobs "${matched_blobs}" || true)

			if [ -n "${matched_key:-}" ]; then
				printf "key::%s\n" "${matched_key}"
				return 0
			fi
		fi

		if [ "${attempt}" -eq 1 ] && prompt_for_yubikey "No inserted YubiKey has a saved signing key for ${user}."; then
			attempt=$((attempt + 1))
			continue
		fi

		return 1
	done

	return 1
}

configured_git_account() {
	github_account=$(git config --get github.account 2> /dev/null || true)
	forgejo_account=$(git config --get forgejo.account 2> /dev/null || true)

	if [ -n "${github_account:-}" ] && [ -n "${forgejo_account:-}" ]; then
		if [ "${github_account}" != "${forgejo_account}" ]; then
			printf "%s\n" "github.account and forgejo.account are both set to different users." >&2
			return 1
		fi

		printf "%s\n" "${github_account}"
		return 0
	fi

	if [ -n "${github_account:-}" ]; then
		printf "%s\n" "${github_account}"
		return 0
	fi

	if [ -n "${forgejo_account:-}" ]; then
		printf "%s\n" "${forgejo_account}"
		return 0
	fi

	printf "%s\n" "No git signing account configured; set github.account or forgejo.account." >&2
	return 1
}

resolve_git() {
	user=${1:-}

	if [ -z "${user:-}" ]; then
		if ! user=$(configured_git_account); then
			return 1
		fi
	fi

	if ! is_safe_user "${user}"; then
		printf "%s\n" "git signing account is not safe for a filename: ${user}" >&2
		return 1
	fi

	match_git_signing_key "${user}"
}

github_accounts() {
	command -v gh 1> /dev/null 2>&1 || return 0

	command gh auth status \
		--hostname github.com \
		--json hosts \
		--jq '.hosts["github.com"] // [] | .[].login' 2> /dev/null |
		awk 'NF {printf "github github.com %s\n", $1}'
}

forgejo_accounts() {
	command -v fj 1> /dev/null 2>&1 || return 0

	command fj --style minimal auth list 2> /dev/null |
		awk 'NF {user=$1; host=$1; sub("@.*$", "", user); sub("^[^@]+@", "", host); if (user && host) printf "forgejo %s %s\n", host, user}'
}

authenticated_accounts() {
	github_accounts
	forgejo_accounts
}

matching_accounts_for_user() {
	user=$1

	authenticated_accounts | awk -v user="${user}" '$3 == user {print}'
}

select_authenticated_user() {
	command -v fzf 1> /dev/null 2>&1 || {
		error "fzf is required to select an account" >&2
		return 1
	}

	users=$(authenticated_accounts | awk 'NF >= 3 && !seen[$3]++ {print $3}')

	if [ -z "${users:-}" ]; then
		error "no authenticated GitHub or Forgejo accounts found" >&2
		return 1
	fi

	if ! selected=$(printf "%s\n" "${users}" | fzf --header='select git account' --select-1); then
		return 1
	fi

	[ -n "${selected:-}" ] || return 1
	printf "%s\n" "${selected}"
}

confirm_unpublished_generation() {
	user=$1

	warn "no authenticated GitHub or Forgejo account found for ${user}; key will not be published"

	if [ ! -r /dev/tty ] || [ ! -w /dev/tty ]; then
		printf "%s\n" "Cannot confirm unpublished key generation without a tty." >&2
		return 1
	fi

	printf "Continue generating an unpublished key? [y/N] " > /dev/tty
	IFS= read -r answer < /dev/tty || answer=

	case "${answer}" in
	y | Y | yes | YES) return 0 ;;
	*) return 1 ;;
	esac
}

publish_key_to_accounts() {
	pub_file=$1
	accounts=$2
	failed=0
	published=0

	while IFS= read -r account; do
		[ -n "${account:-}" ] || continue

		provider=$(printf "%s\n" "${account}" | awk '{print $1}')
		host=$(printf "%s\n" "${account}" | awk '{print $2}')
		account_user=$(printf "%s\n" "${account}" | awk '{print $3}')
		published=1

		case "${provider}" in
		github)
			info "publishing signing key to GitHub as ${account_user}..."
			if command gh auth switch --hostname "${host}" --user "${account_user}" 1> /dev/null 2>&1 && \
				command gh ssh-key add "${pub_file}" --type signing --title "YubiKey signing"; then
				success "published signing key to GitHub as ${account_user}"
			else
				error "failed to publish signing key to GitHub as ${account_user}"
				failed=1
			fi
			;;
		forgejo)
			info "publishing SSH key to Forgejo ${host} as ${account_user}..."
			if command fj -H "${host}" user key upload "${pub_file}" --title "YubiKey signing"; then
				success "published SSH key to Forgejo ${host} as ${account_user}"
			else
				error "failed to publish SSH key to Forgejo ${host} as ${account_user}"
				failed=1
			fi
			;;
		esac
	done <<-EOF
		${accounts}
	EOF

	[ "${published}" -eq 1 ] || return 1
	[ "${failed}" -eq 0 ] || return 1
}

# Load saved Ed25519 security-key stubs into the agent and append the resolved signing key to the
# git allowed_signers file.
setup() {
	user=${1:-}

	info "setting up ssh agent..."

	if ! serials=$(current_serials_or_prompt); then
		error "no YubiKey is currently inserted"
		exit 1
	fi

	if load_current_stubs "${serials}"; then
		success "keys successfully added to agent!"
	else
		error "no saved security-key stubs found for the inserted YubiKey"
		exit 1
	fi

	info "updating git allowed signers..."
	email=$(git config --get user.email 2> /dev/null || true)
	allowed_signers="${XDG_CONFIG_HOME}/private/git/allowed_signers"

	if [ -z "${email:-}" ]; then
		error "user email is not set"
		exit 1
	fi

	if ! key=$(resolve_git "${user}"); then
		error "user signing key is not set"
		exit 1
	fi

	public_key="${key#key::}"

	mkdir -p "$(dirname "${allowed_signers}")"
	touch "${allowed_signers}"

	signer_line="${email} namespaces=\"git\" ${public_key}"

	if grep -qxF "${signer_line}" "${allowed_signers}"; then
		info "${email}: ${public_key} already present in ${allowed_signers}"
	else
		info "adding ${email}: ${public_key} to ${allowed_signers}"
		echo "${signer_line}" >> "${allowed_signers}"
	fi
}

# Generate a resident ed25519-sk key namespaced by user so multiple keys can
# coexist on one security key, then load it via setup.
gen() {
	user="${1:-}"
	publish_failed=0

	if [ -z "${user:-}" ]; then
		if ! user=$(select_authenticated_user); then
			exit 1
		fi
	fi

	if ! is_safe_user "${user}"; then
		error "user must be safe for a filename: ${user}"
		exit 1
	fi

	matching_accounts=$(matching_accounts_for_user "${user}")

	if [ -z "${matching_accounts:-}" ] && ! confirm_unpublished_generation "${user}"; then
		exit 1
	fi

	if ! serial=$(single_current_serial); then
		exit 1
	fi
	key_dir="${key_root}/${serial}"
	key_file="${key_dir}/id_ed25519_sk_${user}"

	mkdir -p "${key_dir}"
	chmod 700 "${key_root}" "${key_dir}"

	if [ -e "${key_file}" ] || [ -e "${key_file}.pub" ]; then
		error "security-key stub already exists: ${key_file}"
		exit 1
	fi

	ssh-keygen \
		-t ed25519-sk \
		-f "${key_file}" \
		-O resident \
		-O verify-required \
		-O no-touch-required \
		-O "application=ssh:${user}" \
		-O "user=${user}" \
		-C "${user}"

	ssh-add "${key_file}"

	if [ -n "${matching_accounts:-}" ] && ! publish_key_to_accounts "${key_file}.pub" "${matching_accounts}"; then
		publish_failed=1
	fi

	setup "${user}"

	if [ "${publish_failed}" -eq 1 ]; then
		exit 1
	fi
}

cmd="${1:-}"
[ "$#" -gt 0 ] && shift || true

case "${cmd}" in
gen | generate)
	gen "$@"
	;;
get)
	provider=
	for arg in "$@"; do
		case "${arg}" in
		--git) provider=git ;;
		*)
			error "unknown option: ${arg}" >&2
			usage
			exit 1
			;;
		esac
	done

	case "${provider}" in
	git) resolve_git ;;
	*) setup ;;
	esac
	;;
'' | -h | --help | help)
	usage
	;;
*)
	error "unknown command: ${cmd}" >&2
	usage
	exit 1
	;;
esac
