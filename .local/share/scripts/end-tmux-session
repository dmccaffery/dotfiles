#!/usr/bin/env sh

set -eu

WORKTREES_DIR="${HOME}/.cache/agent/worktrees"

default_color=$(tput sgr 0)

blue="$(tput setaf 4)"
info() {
	printf "%s==> %s%s\n" "$blue" "$1" "$default_color"
}

green="$(tput setaf 2)"
success() {
	printf "%s==> %s%s\n" "$green" "$1" "$default_color"
}

yellow="$(tput setaf 3)"
warn() {
	printf "%s==> %s%s\n" "$yellow" "$1" "$default_color"
}

red="$(tput setaf 1)"
error() {
	printf "%s==> %s%s\n" "$red" "$1" "$default_color"
}

force=0
case "${1:-}" in
-f | --force)
	force=1
	shift
	;;
esac

if [ ! -d "${WORKTREES_DIR}" ]; then
	warn "no agent worktrees at ${WORKTREES_DIR}"
	exit 0
fi

sel_file=$(mktemp)
trap 'rm -f "${sel_file}"' EXIT

if [ "$#" -gt 0 ]; then
	for arg in "$@"; do
		case "${arg}" in
		/*) printf '%s\n' "${arg}" ;;
		*) printf '%s\n' "${WORKTREES_DIR}/${arg}" ;;
		esac
	done > "${sel_file}"
else
	find "${WORKTREES_DIR}" -mindepth 1 -maxdepth 1 -type d |
		fzf -m --exit-0 --prompt='worktrees to remove > ' > "${sel_file}" || true
fi

if [ ! -s "${sel_file}" ]; then
	exit 0
fi

needs_confirm=0
while IFS= read -r wt; do
	[ -z "${wt}" ] && continue
	if [ ! -d "${wt}" ]; then
		warn "missing: ${wt}"
		continue
	fi
	branch=$(git -C "${wt}" rev-parse --abbrev-ref HEAD 2> /dev/null || echo '?')
	uncommitted=$(git -C "${wt}" status --porcelain 2> /dev/null | wc -l | tr -d ' ')
	unpushed=$(git -C "${wt}" rev-list --count HEAD --not --remotes 2> /dev/null || echo 0)
	if [ "${uncommitted}" != "0" ] || [ "${unpushed}" != "0" ]; then
		warn "$(basename "${wt}") [${branch}] — uncommitted: ${uncommitted}, unpushed: ${unpushed}"
		needs_confirm=1
	else
		info "$(basename "${wt}") [${branch}] — clean"
	fi
done < "${sel_file}"

if [ "${needs_confirm}" -eq 1 ] && [ "${force}" -eq 0 ]; then
	printf '%sproceed with removal? [y/N] %s' "$yellow" "$default_color"
	read -r answer
	case "${answer}" in
	y | Y | yes | YES) ;;
	*)
		error "aborted"
		exit 1
		;;
	esac
fi

while IFS= read -r wt; do
	[ -z "${wt}" ] && continue
	[ ! -d "${wt}" ] && continue
	end-worktree "${wt}"
done < "${sel_file}"
