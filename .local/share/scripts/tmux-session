#!/usr/bin/env sh

set -eu

WORKTREES_DIR="${HOME}/.cache/agent/worktrees"

default_color=$(tput sgr 0 2> /dev/null || true)
blue=$(tput setaf 4 2> /dev/null || true)
green=$(tput setaf 2 2> /dev/null || true)
yellow=$(tput setaf 3 2> /dev/null || true)
red=$(tput setaf 1 2> /dev/null || true)

info() {
	printf "%s==> %s%s\n" "$blue" "$1" "$default_color"
}

success() {
	printf "%s==> %s%s\n" "$green" "$1" "$default_color"
}

warn() {
	printf "%s==> %s%s\n" "$yellow" "$1" "$default_color"
}

error() {
	printf "%s==> %s%s\n" "$red" "$1" "$default_color"
}

sanitize() {
	# tmux >=3.5 rejects '.' in session names, so encode dots before falling back
	# to '-' for any other disallowed character: leading '.' -> 'dot-', trailing
	# '.' -> '-dot', interior '.' -> '-dot-'.
	printf '%s' "${1}" \
		| sed -e 's/^\./dot-/' -e 's/\.$/-dot/' -e 's/\./-dot-/g' \
		| tr -c 'A-Za-z0-9_-' '-'
}

usage() {
	cat >&2 <<-'EOF'
		usage: tmux-session <command> [args]

		commands:
		  start [query] [worktree]   fzf-pick a repo and create/attach a session (optionally per worktree)
		  attach [query]             fzf-pick an existing session and attach (or switch client inside tmux)
		  end [-f] [worktree...]     fzf multi-select agent worktrees and remove them (with dirty warnings)
	EOF
}

# fzf-pick a repo (or operate on a per-worktree checkout) and create/attach a
# session laid out as nvim + zsh + the available coding-agent windows.
start() {
	REPOS_DIR="${REPOS_DIR:-${HOME}/Repos}"
	selected="${1:-}"
	wt="${2:-}"
	claude_bin=$(command -v claude 2> /dev/null || true)
	opencode_bin=$(command -v opencode 2> /dev/null || true)
	codex_bin=$(command -v codex 2> /dev/null || true)

	if [ ! -d "${REPOS_DIR:-}" ]; then
		REPOS_DIR='.'
	fi

	if [ "${selected:-}" = "." ]; then
		REPOS_DIR="${PWD}"
		selected=
	fi

	selected=$(find "${REPOS_DIR}" -type d -mindepth 0 -maxdepth 4 -exec test -d {}/.git \; -print -prune | fzf --query "${selected}" --exit-0 --select-1)

	if [ -z "${selected:-}" ]; then
		exit 0
	fi

	if [ -n "${wt:-}" ]; then
		wt_path=$(worktree start "${selected}" "${wt}")
		selected="${wt_path}"
		name=$(basename -- "${wt_path}")
	else
		name=$(sanitize "$(basename -- "${selected}")")
	fi

	if ! tmux has-session -t "${name}" 2> /dev/null; then
		editor_pane=$(tmux -u new-session -d -P -F '#{pane_id}' -s "${name}" -n ' nvim' -c "${selected}" -x - -y - "${EDITOR}" .)
		editor_window=$(tmux display-message -p -t "${editor_pane}" '#{window_id}')
		tmux split-window -t "${editor_pane}" -v -l '10%' -c "${selected}"
		tmux select-pane -t "${editor_pane}"

		if [ -n "${opencode_bin}" ]; then
			tmux new-window -a -d -t "${editor_window}" -c "${selected}" -n '󰚩  opencode' "${opencode_bin}"
		fi

		if [ -n "${claude_bin}" ]; then
			tmux new-window -a -d -t "${editor_window}" -c "${selected}" -n '󰯉  claude' "${claude_bin}"
		fi

		if [ -n "${codex_bin}" ]; then
			tmux new-window -a -d -t "${editor_window}" -c "${selected}" -n '󱙺  codex' "${codex_bin}"
		fi

		tmux new-window -a -d -t "${editor_window}" -n ' zsh' -c "${selected}"
	fi

	# Set the terminal window/tab title to the session name (OSC 0), otherwise the
	# terminal keeps showing the launching command (e.g. 'sts dotfiles').
	printf '\033]0;%s\007' "${name}"

	tmux -u attach-session -t "${name}" -c "${selected}"
}

# fzf-pick a running session and attach (or switch the client when inside tmux).
attach() {
	selected="${1:-}"

	if [ ! -d "${REPOS_DIR:-}" ]; then
		REPOS_DIR='.'
	fi

	if [ "${selected:-}" = "." ]; then
		REPOS_DIR="${PWD}"
		selected=
	fi

	selected=$(tmux list-session -F '#S' | fzf --query "${selected}" --select-1)

	if [ -z "${selected:-}" ]; then
		exit 0
	fi

	name=$(basename "${selected}" | tr . _)

	tmux -u attach-session -t "${name}" 2> /dev/null || tmux switch-client -t "${name}"
}

# fzf multi-select agent worktrees, warn on dirty/unpushed state, then hand each
# off to `worktree end`.
end() {
	force=0
	case "${1:-}" in
	-f | --force)
		force=1
		shift
		;;
	esac

	if [ ! -d "${WORKTREES_DIR}" ]; then
		warn "no agent worktrees at ${WORKTREES_DIR}"
		exit 0
	fi

	sel_file=$(mktemp)
	trap 'rm -f "${sel_file}"' EXIT

	if [ "$#" -gt 0 ]; then
		for arg in "$@"; do
			case "${arg}" in
			/*) printf '%s\n' "${arg}" ;;
			*) printf '%s\n' "${WORKTREES_DIR}/${arg}" ;;
			esac
		done > "${sel_file}"
	else
		find "${WORKTREES_DIR}" -mindepth 1 -maxdepth 1 -type d \
			| fzf -m --exit-0 --prompt='worktrees to remove > ' > "${sel_file}" || true
	fi

	if [ ! -s "${sel_file}" ]; then
		exit 0
	fi

	needs_confirm=0
	while IFS= read -r wt; do
		[ -z "${wt}" ] && continue
		if [ ! -d "${wt}" ]; then
			warn "missing: ${wt}"
			continue
		fi
		branch=$(git -C "${wt}" rev-parse --abbrev-ref HEAD 2> /dev/null || echo '?')
		uncommitted=$(git -C "${wt}" status --porcelain 2> /dev/null | wc -l | tr -d ' ')
		unpushed=$(git -C "${wt}" rev-list --count HEAD --not --remotes 2> /dev/null || echo 0)
		if [ "${uncommitted}" != "0" ] || [ "${unpushed}" != "0" ]; then
			warn "$(basename "${wt}") [${branch}] — uncommitted: ${uncommitted}, unpushed: ${unpushed}"
			needs_confirm=1
		else
			info "$(basename "${wt}") [${branch}] — clean"
		fi
	done < "${sel_file}"

	if [ "${needs_confirm}" -eq 1 ] && [ "${force}" -eq 0 ]; then
		printf '%sproceed with removal? [y/N] %s' "$yellow" "$default_color"
		read -r answer
		case "${answer}" in
		y | Y | yes | YES) ;;
		*)
			error "aborted"
			exit 1
			;;
		esac
	fi

	while IFS= read -r wt; do
		[ -z "${wt}" ] && continue
		[ ! -d "${wt}" ] && continue
		worktree end "${wt}"
	done < "${sel_file}"
}

cmd="${1:-}"
[ "$#" -gt 0 ] && shift || true

case "${cmd}" in
start) start "$@" ;;
attach) attach "$@" ;;
end) end "$@" ;;
'' | -h | --help | help) usage ;;
*)
	error "unknown command: ${cmd}"
	usage
	exit 1
	;;
esac
