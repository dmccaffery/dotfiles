#!/usr/bin/env sh

set -eu

# Glyphs for the OSC (non-tmux) terminal-title fallback. Inside tmux the glyph and
# colour are chosen by theme.conf from the @claude_status state token set below.
waiting_glyph='● '
attention_glyph='󰂚 '

state="${1:-clear}"

if [ -n "${TMUX:-}" ]; then
	# Inside tmux: tmux swallows OSC title sequences (set-titles is off), so flag the
	# window via a per-window option holding a state token (waiting | attention) that
	# theme.conf maps to a colour + glyph. Target the pane Claude runs in via $TMUX_PANE.
	case "${state}" in
	waiting | attention)
		tmux set-window-option -t "${TMUX_PANE:-}" @claude_status "${state}" 2> /dev/null || true
		;;
	*)
		tmux set-window-option -t "${TMUX_PANE:-}" -u @claude_status 2> /dev/null || true
		;;
	esac
else
	# Outside tmux: set the terminal (e.g. Ghostty) tab title via OSC 0, routed to the
	# controlling tty since the hook's stdout is captured by Claude Code.
	title=$(basename -- "${PWD}")
	case "${state}" in
	waiting)
		(printf '\033]0;%s%s\007' "${waiting_glyph}" "${title}" > /dev/tty) 2> /dev/null || true
		;;
	attention)
		(printf '\033]0;%s%s\007' "${attention_glyph}" "${title}" > /dev/tty) 2> /dev/null || true
		;;
	*)
		(printf '\033]0;%s\007' "${title}" > /dev/tty) 2> /dev/null || true
		;;
	esac
fi
