#!/usr/bin/env sh

set -eu

REPOS_DIR="${REPOS_DIR:-${HOME}/Repos}"
selected="${1:-}"
worktree="${2:-}"

if [ ! -d "${REPOS_DIR:-}" ]; then
	REPOS_DIR='.'
fi

if [ "${selected:-}" = "." ]; then
	REPOS_DIR="${PWD}"
	selected=
fi

selected=$(find "${REPOS_DIR}" -type d -mindepth 0 -maxdepth 4 -exec test -d {}/.git \; -print -prune | fzf --query "${selected}" --exit-0 --select-1)

if [ -z "${selected:-}" ]; then
	exit 0
fi

repo_name=$(basename "${selected}" | tr . _)

if [ -n "${worktree:-}" ]; then
	worktree_sanitized=$(printf '%s' "${worktree}" | tr -c 'A-Za-z0-9._-' '-')
	worktree_full="${repo_name}-${worktree_sanitized}"
	worktree_path="${HOME}/.cache/agent/worktrees/${worktree_full}"
	branch="agent/${worktree_full}"

	if [ ! -d "${worktree_path}" ]; then
		if git -C "${selected}" show-ref --verify --quiet "refs/heads/${branch}"; then
			git -C "${selected}" worktree add "${worktree_path}" "${branch}"
		else
			git -C "${selected}" worktree add -b "${branch}" "${worktree_path}"
		fi
	fi

	selected="${worktree_path}"
	name="${repo_name}/${worktree_sanitized}"
else
	name="${repo_name}"
fi

printf '\033]0;%s\007' "${name}" || true

if ! tmux has-session -t "${name}" 2> /dev/null; then
	tmux -u new-session -d -s "${name}" -n ' nvim' -c "${selected}" -x - -y - "${EDITOR}" . \; \
		split-window -v -l '10%' -c "${selected}" \; \
		select-pane -t 1 \; \
		new-window -a -d -c "${selected}" -n '󰯉 claude (agent)' claude \; \
		new-window -a -d -c "${selected}"
fi

tmux -u attach-session -t "${name}" -c "${selected}"
