#!/usr/bin/env sh

set -eu

sanitize() {
	# tmux >=3.5 rejects '.' in session names, so encode dots before falling back
	# to '-' for any other disallowed character: leading '.' -> 'dot-', trailing
	# '.' -> '-dot', interior '.' -> '-dot-'.
	printf '%s' "${1}" |
		sed -e 's/^\./dot-/' -e 's/\.$/-dot/' -e 's/\./-dot-/g' |
		tr -c 'A-Za-z0-9_-' '-'
}

REPOS_DIR="${REPOS_DIR:-${HOME}/Repos}"
selected="${1:-}"
worktree="${2:-}"
claude_bin=$(command -v claude 2> /dev/null || true)
opencode_bin=$(command -v opencode 2> /dev/null || true)

if [ ! -d "${REPOS_DIR:-}" ]; then
	REPOS_DIR='.'
fi

if [ "${selected:-}" = "." ]; then
	REPOS_DIR="${PWD}"
	selected=
fi

selected=$(find "${REPOS_DIR}" -type d -mindepth 0 -maxdepth 4 -exec test -d {}/.git \; -print -prune | fzf --query "${selected}" --exit-0 --select-1)

if [ -z "${selected:-}" ]; then
	exit 0
fi

if [ -n "${worktree:-}" ]; then
	worktree=$(start-worktree "${selected}" "${worktree}")
	selected="${worktree}"
	name=$(basename -- "${worktree}")
else
	name=$(sanitize "$(basename -- "${selected}")")
fi

if ! tmux has-session -t "${name}" 2> /dev/null; then
	editor_pane=$(tmux -u new-session -d -P -F '#{pane_id}' -s "${name}" -n ' nvim' -c "${selected}" -x - -y - "${EDITOR}" .)
	editor_window=$(tmux display-message -p -t "${editor_pane}" '#{window_id}')
	tmux split-window -t "${editor_pane}" -v -l '10%' -c "${selected}"
	tmux select-pane -t "${editor_pane}"

	if [ -n "${opencode_bin}" ]; then
		tmux new-window -a -d -t "${editor_window}" -c "${selected}" -n '󰚩  opencode (primary)' "${opencode_bin}"
	fi

	if [ -n "${claude_bin}" ]; then
		tmux new-window -a -d -t "${editor_window}" -c "${selected}" -n '󰯉  claude (primary)' "${claude_bin}"
	fi

	tmux new-window -a -d -t "${editor_window}" -n ' zsh' -c "${selected}"
fi

# Set the terminal window/tab title to the session name (OSC 0), otherwise the
# terminal keeps showing the launching command (e.g. 'sts dotfiles').
printf '\033]0;%s\007' "${name}"

tmux -u attach-session -t "${name}" -c "${selected}"
