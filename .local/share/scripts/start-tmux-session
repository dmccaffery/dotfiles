#!/usr/bin/env sh

set -eu

sanitize() {
	# tmux >=3.5 rejects '.' in session names, so encode dots before falling back
	# to '-' for any other disallowed character: leading '.' -> 'dot-', trailing
	# '.' -> '-dot', interior '.' -> '-dot-'.
	printf '%s' "${1}" |
		sed -e 's/^\./dot-/' -e 's/\.$/-dot/' -e 's/\./-dot-/g' |
		tr -c 'A-Za-z0-9_-' '-'
}

REPOS_DIR="${REPOS_DIR:-${HOME}/Repos}"
selected="${1:-}"
worktree="${2:-}"

if [ ! -d "${REPOS_DIR:-}" ]; then
	REPOS_DIR='.'
fi

if [ "${selected:-}" = "." ]; then
	REPOS_DIR="${PWD}"
	selected=
fi

selected=$(find "${REPOS_DIR}" -type d -mindepth 0 -maxdepth 4 -exec test -d {}/.git \; -print -prune | fzf --query "${selected}" --exit-0 --select-1)

if [ -z "${selected:-}" ]; then
	exit 0
fi

if [ -n "${worktree:-}" ]; then
	worktree=$(start-worktree "${selected}" "${worktree}")
	selected="${worktree}"
	name=$(basename -- "${worktree}")
else
	name=$(sanitize "$(basename -- "${selected}")")
fi

if ! tmux has-session -t "${name}" 2> /dev/null; then
	tmux -u new-session -d -s "${name}" -n ' nvim' -c "${selected}" -x - -y - "${EDITOR}" . \; \
		split-window -v -l '10%' -c "${selected}" \; \
		select-pane -t 1 \; \
		new-window -a -d -c "${selected}" -n '󰯉 claude (primary)' claude \; \
		new-window -a -d -c "${selected}" -n '󰚩 opencode (primary)' opencode
fi

# Set the terminal window/tab title to the session name (OSC 0), otherwise the
# terminal keeps showing the launching command (e.g. 'sts dotfiles').
printf '\033]0;%s\007' "${name}"

tmux -u attach-session -t "${name}" -c "${selected}"
