#!/usr/bin/env bash

set -euo pipefail

INSTALL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SETUP_DIR="${INSTALL_DIR}/setup"
SCRIPT_DIR="${INSTALL_DIR}/.local/share/scripts"

# shellcheck source=./setup/printing.sh
. "${SETUP_DIR}/printing.sh"

"${SCRIPT_DIR}/disable-zs"

"${SETUP_DIR}/prerequisites.sh"
"${SETUP_DIR}/defaults.sh"
"${SETUP_DIR}/xdg.sh"
"${SETUP_DIR}/brews.sh"
"${SETUP_DIR}/stow.sh"
"${SETUP_DIR}/shell.sh"

"${SCRIPT_DIR}/enable-zs"

"${SCRIPT_DIR}/git-auth"
"${SCRIPT_DIR}/get-sk-ssh"

fastfetch
printf '\n'
